exports[`search (P6) > search page > renders results with links to the posts' blog URLs 1`] = `"<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>Search — Nostrbook</title><link rel="stylesheet" href="/css/style.css"/></head><body><main class="search"><p class="site-nav"><a href="/">Nostrbook</a> · <a href="/discover">Discover</a></p><h1>Search</h1><form method="get" action="/search" class="search-form" role="search"><input type="search" name="q" value="hello" maxlength="256" placeholder="Search posts" aria-label="Search posts"/> <button type="submit">Search</button></form><p class="search-count">1 result for “hello”</p><ul class="post-list feed-list"><li class="post-item"><a class="post-link" href="https://alice.nostrbook.net/hello-world">Hello world</a> <span class="post-author">by <a href="https://alice.nostrbook.net/">@alice</a></span> <time class="post-date" datetime="2023-11-14">2023-11-14</time><p class="post-summary">Alice&#39;s first Nostrbook test post</p></li></ul></main></body></html>"`;

exports[`search (P6) > search page > serves the bare form without a query (no results section) 1`] = `"<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>Search — Nostrbook</title><link rel="stylesheet" href="/css/style.css"/></head><body><main class="search"><p class="site-nav"><a href="/">Nostrbook</a> · <a href="/discover">Discover</a></p><h1>Search</h1><form method="get" action="/search" class="search-form" role="search"><input type="search" name="q" value="" maxlength="256" placeholder="Search posts" aria-label="Search posts"/> <button type="submit">Search</button></form><p class="search-hint">Search every post published on nostrbook.net.</p></main></body></html>"`;
