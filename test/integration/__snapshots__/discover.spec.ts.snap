exports[`discover feed (P6) > matches the snapshot 1`] = `"<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>Discover — Nostrbook</title><link rel="stylesheet" href="/css/style.css"/></head><body><main class="discover"><p class="site-nav"><a href="/">Nostrbook</a> · <a href="/search">Search</a></p><h1>Discover</h1><p class="page-intro">Recent posts from blogs on nostrbook.net.</p><ul class="post-list feed-list"><li class="post-item"><a class="post-link" href="https://bob.nostrbook.net/bob-first">Bob&#39;s first post</a> <span class="post-author">by <a href="https://bob.nostrbook.net/">@bob</a></span> <time class="post-date" datetime="2023-11-14">2023-11-14</time><p class="post-summary">A second author for feed/search tests</p></li><li class="post-item"><a class="post-link" href="https://alice.nostrbook.net/xss-test">XSS &lt;script&gt;alert(&#39;title&#39;)&lt;/script&gt; torture</a> <span class="post-author">by <a href="https://alice.nostrbook.net/">@alice</a></span> <time class="post-date" datetime="2023-11-14">2023-11-14</time><p class="post-summary">&lt;img src=x onerror=alert(&#39;summary&#39;)&gt;</p></li><li class="post-item"><a class="post-link" href="https://alice.nostrbook.net/markdown-torture">Markdown torture test</a> <span class="post-author">by <a href="https://alice.nostrbook.net/">@alice</a></span> <time class="post-date" datetime="2023-11-14">2023-11-14</time><p class="post-summary">Every markdown feature in one post</p></li><li class="post-item"><a class="post-link" href="https://alice.nostrbook.net/hello-world">Hello world</a> <span class="post-author">by <a href="https://alice.nostrbook.net/">@alice</a></span> <time class="post-date" datetime="2023-11-14">2023-11-14</time><p class="post-summary">Alice&#39;s first Nostrbook test post</p></li></ul></main></body></html>"`;

exports[`landing page (P6 polish) > pitches the product and carries the login CTA 1`] = `"<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1"/><title>Nostrbook — Nostr-native blogging</title><link rel="stylesheet" href="/css/style.css"/></head><body><main class="landing"><h1>Nostrbook</h1><p class="tagline">Nostr-native blogging. Your posts are NIP-23 events signed by your key — we just render them beautifully at <code>you.nostrbook.net</code>.</p><p class="landing-cta"><a class="cta-button" href="/login">Sign in with Nostr</a> <a class="cta-secondary" href="/discover">Discover blogs</a></p><section class="landing-pitch"><h2>Your keys, your words</h2><p>Every post is a signed Nostr event living on public relays. Nostrbook mirrors and renders them — it never owns them. Leave any time and take everything with you; no export button needed.</p><h2>A real blog, not a feed</h2><p>Claim a handle and get a clean site at <code>handle.nostrbook.net</code> with RSS and Atom feeds, a sitemap, your own theme CSS, and a <code>handle@nostrbook.net</code> NIP-05 identifier.</p><h2>Write anywhere</h2><p>Use the built-in markdown editor with NIP-07 signing, or publish long-form posts from any Nostr client — Nostrbook keeps your blog in sync with the relays either way.</p></section><p class="landing-links"><a href="/discover">Discover recent posts</a> · <a href="/search">Search posts</a> · <a href="/login">Sign in</a></p></main></body></html>"`;
